generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  userId   String
  currency String
  balance  Decimal @default(0) @db.Decimal(36, 18)

  @@id([userId, currency])
  @@map("wallets")
}

model Transaction {
  id             String          @id @default(uuid())
  userId         String
  currency       String
  amount         Decimal         @db.Decimal(36, 18)
  type           TransactionType
  reason         String?
  idempotencyKey String          @unique

  createdAt DateTime @default(now())

  @@index([userId, currency, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("transactions")
}

model IdempotencyRecord {
  key           String   @id
  operationType String
  responseBody  Json
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@map("idempotency_records")
}

model DailyUsage {
  userId   String
  currency String
  date     DateTime @db.Date
  total    Decimal  @default(0) @db.Decimal(36, 18)

  @@id([userId, currency, date])
  @@map("daily_usage")
}

enum TransactionType {
  TOPUP
  CHARGE
}
